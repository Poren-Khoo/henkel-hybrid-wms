    {
        "id": "mqtt_in_release_hold",
        "type": "mqtt in",
        "z": "99f9fe79da9e4937",
        "g": "c7ca76b09ddf4c7e",
        "name": "Action: Release_Hold",
        "topic": "Henkelv2/Shanghai/Logistics/Outbound/Action/Release_Hold",
        "qos": "0",
        "datatype": "json",
        "broker": "a749d056cff1a785",
        "inputs": 0,
        "x": 2300,

    {
        "id": "func_generate_picking_queue",
        "type": "function",
        "z": "99f9fe79da9e4937",
        "g": "group_mock_data_generators",
        "name": "Generate Pick Tasks",
        "func": "const statuses = ['PENDING', 'IN_PROGRESS', 'COMPLETED'];\nconst materials = ['GLUE-500', 'SEALANT-X', 'ADHESIVE-PRO', 'COATING-UV'];\nconst locations = ['A-01-01', 'A-02-03', 'B-01-02', 'B-03-01', 'C-02-04'];\n\nlet tasks = [];\nlet count = Math.floor(Math.random() * 8) + 5;\n\nfor (let i = 0; i < count; i++) {\n    let task = {\n        task_id: 'PICK-' + Date.now() + '-' + i,\n        status: statuses[Math.floor(Math.random() * statuses.length)],\n        material_code: materials[Math.floor(Math.random() * materials.length)],\n        material_name: 'Material ' + (i + 1),\n        batch: 'B2026' + String(Math.floor(Math.random() * 1000)).padStart(3, '0'),\n        from_location: locations[Math.floor(Math.random() * locations.length)],\n        to_location: 'STAGE-0' + (Math.floor(Math.random() * 3) + 1),\n        qty: Math.floor(Math.random() * 50) + 10,\n        uom: 'EA',\n        wave_id: 'WAVE-' + Math.floor(Math.random() * 100),\n        dn_no: 'DN-' + Math.floor(Math.random() * 10000),\n        priority: Math.random() > 0.7 ? 'HIGH' : 'NORMAL',\n        created_at: Date.now()\n    };\n    tasks.push(task);\n}\n\nmsg.payload = {\n    version: '1.0',\n    topics: [{ path: msg.topic, type: 'state', value: { tasks: tasks } }]\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",

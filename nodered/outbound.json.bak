                "mqtt_out_dn_state_hold"
            ]
        ]
    },
    {
        "id": "mqtt_in_wave_create",
        "type": "mqtt in",
        "z": "99f9fe79da9e4937",
        "g": "c7ca76b09ddf4c7e",
        "name": "Action: Create_Wave",
        "topic": "Henkelv2/Shanghai/Logistics/Outbound/Action/Create_Wave",
        "qos": "0",
        "datatype": "json",
        "broker": "a749d056cff1a785",
        "inputs": 0,
        "x": 2300,
        "y": 240,
        "wires": [
            [
                "func_wave_create"
            ]
        ]
    },
    {
        "id": "func_wave_create",
        "type": "function",
        "z": "99f9fe79da9e4937",
        "g": "c7ca76b09ddf4c7e",
        "name": "Create Wave",
        "func": "// TOPICS\nconst TOPIC_WAVE_STATE = \"Henkelv2/Shanghai/Logistics/Outbound/State/Wave_List\";\nconst TOPIC_DN_STATE = \"Henkelv2/Shanghai/Logistics/Outbound/State/DN_Workflow\";\n\nlet action = msg.payload;\n// Expected: { wave_id?, ship_date, carrier, route, pick_method, delivery_ids: [] }\n\n// 1. Get DBs\nlet waveDB = global.get('wave_db') || { items: [] };\nlet dnDB = global.get('outbound_dn_db') || { items: [] };\n\n// 2. Create wave\nlet newWave = {\n    wave_id: action.wave_id || 'WAVE-' + Date.now(),\n    status: 'PLANNED',\n    ship_date: action.ship_date || null,\n    carrier: action.carrier || null,\n    route: action.route || null,\n    pick_method: action.pick_method || 'BATCH',\n    delivery_ids: action.delivery_ids || [],\n    delivery_count: (action.delivery_ids || []).length,\n    line_count: 0,\n    picks_completed: 0,\n    picks_total: 0,\n    created_at: Date.now(),\n    created_by: action.operator || 'System'\n};\n\n// 3. Count lines from deliveries\nlet lineCount = 0;\naction.delivery_ids?.forEach(dnId => {\n    let order = dnDB.items.find(o => o.dn_no === dnId || o.id === dnId);\n    if (order) {\n        lineCount += (order.lines || []).length;\n        // Update order status and wave assignment\n        order.wave_id = newWave.wave_id;\n        order.status = 'WAVE_ASSIGNED';\n    }\n});\nnewWave.line_count = lineCount;\n\n// 4. Add to DB\nwaveDB.items.unshift(newWave);\n\n// 5. Save\nglobal.set('wave_db', waveDB);\nglobal.set('outbound_dn_db', dnDB);\n\n// 6. Prepare outputs\nlet msgWave = {\n    topic: TOPIC_WAVE_STATE,\n    payload: { version: \"1.0\", topics: [{ path: TOPIC_WAVE_STATE, type: \"state\", value: waveDB }] }\n};\n\nlet msgDN = {\n    topic: TOPIC_DN_STATE,\n    payload: { version: \"1.0\", topics: [{ path: TOPIC_DN_STATE, type: \"state\", value: dnDB }] }\n};\n\nreturn [msgWave, msgDN];",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 2570,
        "y": 240,
        "wires": [
            [
                "mqtt_out_wave_state"
            ],
            [
                "mqtt_out_dn_state_hold"
            ]
        ]
    },
    {
        "id": "mqtt_out_wave_state",
        "type": "mqtt out",
        "z": "99f9fe79da9e4937",
        "g": "c7ca76b09ddf4c7e",
        "name": "Publish: Wave List",
        "topic": "",
        "qos": "0",

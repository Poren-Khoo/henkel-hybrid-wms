        "name": "Confirm Stage",
        "func": "const TOPIC_STAGING = \"Henkelv2/Shanghai/Logistics/Outbound/State/Staging_Area\";\n\nlet action = msg.payload;\n// Expected: { area_id, dn_no, operator, timestamp }\n\nlet staging = global.get('staging_areas') || { areas: [] };\nif (!staging.areas || !Array.isArray(staging.areas)) {\n    staging.areas = [\n        { area_id: 'STAGE-01', items: [] },\n        { area_id: 'STAGE-02', items: [] },\n        { area_id: 'STAGE-03', items: [] }\n    ];\n}\n\nlet area = staging.areas.find(a => a.area_id === action.area_id);\nif (!area) {\n    area = { area_id: action.area_id, items: [] };\n    staging.areas.push(area);\n}\n\narea.items = area.items.filter(i => i.dn_no !== action.dn_no);\narea.items.push({\n    dn_no: action.dn_no,\n    staged_at: Date.now(),\n    operator: action.operator || 'System'\n});\n\nglobal.set('staging_areas', staging);\n\nmsg.topic = TOPIC_STAGING;\nmsg.payload = {\n    version: \"1.0\",\n    topics: [{ path: TOPIC_STAGING, type: \"state\", value: staging }]\n};\nreturn msg;",

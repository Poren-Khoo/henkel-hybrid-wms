    {
        "id": "func_remove_from_wave",
        "type": "function",
        "z": "99f9fe79da9e4937",
        "g": "c7ca76b09ddf4c7e",
        "name": "Remove Order from Wave",
        "func": "// TOPICS\nconst TOPIC_WAVE_STATE = \"Henkelv2/Shanghai/Logistics/Outbound/State/Wave_List\";\nconst TOPIC_DN_STATE = \"Henkelv2/Shanghai/Logistics/Outbound/State/DN_Workflow\";\n\nlet action = msg.payload;\n// Expected: { dn_no }\n\n// 1. Get DBs\nlet waveDB = global.get('wave_db') || { items: [] };\nlet dnDB = global.get('outbound_dn_db') || { items: [] };\n\n// 2. Find order\nlet order = dnDB.items.find(o => o.dn_no === action.dn_no || o.id === action.dn_no);\nif (!order) {\n    node.warn(\"Remove from Wave Error: Order not found \" + action.dn_no);\n    return null;\n}\n\nif (!order.wave_id) {\n    node.warn(\"Remove from Wave Error: Order not in a wave\");\n    return null;\n}\n\n// 3. Find wave and remove order\nlet wave = waveDB.items.find(w => w.wave_id === order.wave_id);\nif (wave) {\n    if (wave.status !== 'PLANNED') {\n        node.warn(\"Remove from Wave Error: Cannot modify wave in status \" + wave.status);\n        return null;\n    }\n    \n    wave.delivery_ids = wave.delivery_ids.filter(id => id !== order.dn_no && id !== order.id);\n    wave.delivery_count = wave.delivery_ids.length;\n    wave.line_count -= (order.lines || []).length;\n}\n\n// 4. Update order\norder.wave_id = null;\norder.status = 'RELEASED';\n\n// 5. Save\nglobal.set('wave_db', waveDB);\nglobal.set('outbound_dn_db', dnDB);\n\n// 6. Prepare outputs\nlet msgWave = {\n    topic: TOPIC_WAVE_STATE,\n    payload: { version: \"1.0\", topics: [{ path: TOPIC_WAVE_STATE, type: \"state\", value: waveDB }] }\n};\n\nlet msgDN = {\n    topic: TOPIC_DN_STATE,\n    payload: { version: \"1.0\", topics: [{ path: TOPIC_DN_STATE, type: \"state\", value: dnDB }] }\n};\n\nreturn [msgWave, msgDN];",
        "outputs": 2,

    {
        "id": "1842d82103e22563",
        "type": "switch",
        "z": "99f9fe79da9e4937",
        "g": "5537d7f87b30f6d5",
        "name": "Check Warehouse Type",
        "property": "payload.warehouse_type",
        "propertyType": "msg",
        "rules": [

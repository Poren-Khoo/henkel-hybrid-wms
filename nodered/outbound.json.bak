    {
        "id": "mqtt_in_wave_release",
        "type": "mqtt in",
        "z": "99f9fe79da9e4937",
        "g": "c7ca76b09ddf4c7e",
        "name": "Action: Release_Wave",
        "topic": "Henkelv2/Shanghai/Logistics/Outbound/Action/Release_Wave",
        "qos": "0",
        "datatype": "json",
        "broker": "a749d056cff1a785",
        "inputs": 0,
        "x": 2300,
        "y": 600,
        "wires": [
            [
                "func_wave_release"
            ]
        ]
    },
    {
        "id": "func_wave_release",
        "type": "function",
        "z": "99f9fe79da9e4937",
        "g": "c7ca76b09ddf4c7e",
        "name": "Release Wave (Trigger Allocation)",
        "func": "// TOPICS\nconst TOPIC_WAVE_STATE = \"Henkelv2/Shanghai/Logistics/Outbound/State/Wave_List\";\nconst TOPIC_DN_STATE = \"Henkelv2/Shanghai/Logistics/Outbound/State/DN_Workflow\";\nconst TOPIC_INVENTORY = \"Henkelv2/Shanghai/Logistics/Internal/Ops/State/Inventory_Level\";\nconst TOPIC_TASKS = \"Henkelv2/Shanghai/Logistics/Outbound/State/Picking_Tasks\";\n\nlet action = msg.payload;\n// Expected: { wave_id }\n\n// 1. Get DBs\nlet waveDB = global.get('wave_db') || { items: [] };\nlet dnDB = global.get('outbound_dn_db') || { items: [] };\nlet inventory = global.get('internal_stock_list') || [];\nlet taskDB = global.get('outbound_task_db') || { items: [] };\n\n// 2. Find wave\nlet wave = waveDB.items.find(w => w.wave_id === action.wave_id);\nif (!wave) {\n    node.warn(\"Release Wave Error: Wave not found \" + action.wave_id);\n    return null;\n}\n\nif (wave.status !== 'PLANNED') {\n    node.warn(\"Release Wave Error: Wave not in PLANNED status\");\n    return null;\n}\n\n// 3. Update wave status\nwave.status = 'RELEASED';\nwave.released_at = Date.now();\nwave.released_by = action.operator || 'System';\n\n// 4. Process each delivery in the wave - Run allocation\nlet totalPicks = 0;\nlet allocationResults = [];\n\nwave.delivery_ids.forEach(dnId => {\n    let order = dnDB.items.find(o => o.dn_no === dnId || o.id === dnId);\n    if (!order) return;\n    \n    order.status = 'ALLOCATING';\n    \n    // Simple FEFO allocation logic\n    (order.lines || []).forEach(line => {\n        // Find available stock\n        let candidates = inventory.filter(item =>\n            item.sku === line.code &&\n            item.status === 'AVAILABLE'\n        );\n        \n        // Sort by expiry (FEFO)\n        candidates.sort((a, b) => {\n            let dateA = a.expiry_date || 9999999999999;\n            let dateB = b.expiry_date || 9999999999999;\n            return dateA - dateB;\n        });\n        \n        let needed = line.qty || 0;\n        let allocated = 0;\n        \n        for (let batch of candidates) {\n            if (needed <= 0) break;\n            if (batch.qty <= 0) continue;\n            \n            let takeQty = Math.min(batch.qty, needed);\n            \n            // Mark batch as allocated\n            batch.status = 'ALLOCATED';\n            batch.allocated_to = order.dn_no || order.id;\n            \n            // Create pick task\n            let newTask = {\n                task_id: 'PICK-' + Date.now() + '-' + Math.floor(Math.random() * 1000),\n                wave_id: wave.wave_id,\n                dn_no: order.dn_no || order.id,\n                batch_id: batch.batch_id,\n                material_code: batch.sku,\n                material_name: batch.desc,\n                qty: takeQty,\n                from_loc: batch.location || 'ZONE-A',\n                to_loc: 'STAGING-01',\n                status: 'PENDING',\n                priority: order.priority || 'NORMAL',\n                created_at: Date.now()\n            };\n            taskDB.items.unshift(newTask);\n            totalPicks++;\n            \n            needed -= takeQty;\n            allocated += takeQty;\n        }\n        \n        // Update line allocation\n        line.qty_allocated = allocated;\n        \n        allocationResults.push({\n            dn_no: order.dn_no || order.id,\n            line_code: line.code,\n            requested: line.qty,\n            allocated: allocated,\n            short: needed > 0 ? needed : 0\n        });\n    });\n    \n    // Update order status based on allocation\n    let allAllocated = (order.lines || []).every(l => (l.qty_allocated || 0) >= (l.qty || 0));\n    let anyAllocated = (order.lines || []).some(l => (l.qty_allocated || 0) > 0);\n    \n    if (allAllocated) {\n        order.status = 'ALLOCATED';\n        order.allocated_at = Date.now();\n    } else if (anyAllocated) {\n        order.status = 'ALLOCATED'; // Partial - proceed anyway\n        order.partial_allocation = true;\n    } else {\n        order.status = 'BACKORDER';\n    }\n});\n\nwave.picks_total = totalPicks;\nwave.status = 'IN_PROGRESS';\n\n// 5. Save all\nglobal.set('wave_db', waveDB);\nglobal.set('outbound_dn_db', dnDB);\nglobal.set('internal_stock_list', inventory);\nglobal.set('outbound_task_db', taskDB);\n\n// 6. Prepare outputs\nlet msgWave = {\n    topic: TOPIC_WAVE_STATE,\n    payload: { version: \"1.0\", topics: [{ path: TOPIC_WAVE_STATE, type: \"state\", value: waveDB }] }\n};\n\nlet msgDN = {\n    topic: TOPIC_DN_STATE,\n    payload: { version: \"1.0\", topics: [{ path: TOPIC_DN_STATE, type: \"state\", value: dnDB }] }\n};\n\nlet msgInv = {\n    topic: TOPIC_INVENTORY,\n    payload: { version: \"1.0\", topics: [{ path: TOPIC_INVENTORY, type: \"state\", value: { last_updated: Date.now(), stock_items: inventory } }] }\n};\n\nlet msgTasks = {\n    topic: TOPIC_TASKS,\n    payload: { version: \"1.0\", topics: [{ path: TOPIC_TASKS, type: \"state\", value: taskDB }] }\n};\n\nreturn [msgWave, msgDN, msgInv, msgTasks];",

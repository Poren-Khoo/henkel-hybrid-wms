        "type": "function",
        "z": "99f9fe79da9e4937",
        "g": "c7ca76b09ddf4c7e",
        "name": "Confirm Pick",
        "func": "const TOPIC_PICK_QUEUE = \"Henkelv2/Shanghai/Logistics/Outbound/State/Picking_Queue\";\nconst TOPIC_DN_STATE = \"Henkelv2/Shanghai/Logistics/Outbound/State/DN_Workflow\";\n\nlet action = msg.payload;\n// Expected: { task_id, picked_qty?, qty_picked?, operator, timestamp } or { task_id, order_id, sku, qty_picked, ... }\n\nlet taskDB = global.get('outbound_task_db') || { items: [] };\nlet dnDB = global.get('outbound_dn_db') || { items: [] };\nlet waveDB = global.get('wave_db') || { items: [] };\n\nlet task = taskDB.items.find(t => t.task_id === action.task_id || t.task_id === action.task_id);\nif (!task) {\n    node.warn(\"Confirm Pick: Task not found \" + action.task_id);\n    return null;\n}\n\ntask.status = 'COMPLETED';\ntask.completed_at = Date.now();\ntask.picked_qty = action.picked_qty ?? action.qty_picked ?? task.qty;\ntask.operator = action.operator || 'System';\n\nlet dnNo = task.dn_no || task.order_id;\nlet order = dnDB.items.find(o => o.dn_no === dnNo || o.id === dnNo);\nif (order) {\n    order.status = 'PICKING';\n    let wave = waveDB.items.find(w => w.wave_id === (task.wave_id || order.wave_id));\n    if (wave) {\n        wave.picks_completed = (wave.picks_completed || 0) + 1;\n    }\n}\n\nglobal.set('outbound_task_db', taskDB);\nglobal.set('outbound_dn_db', dnDB);\nglobal.set('wave_db', waveDB);\n\nlet payloadQueue = { version: \"1.0\", topics: [{ path: TOPIC_PICK_QUEUE, type: \"state\", value: { tasks: taskDB.items } }] };\nlet payloadDN = { version: \"1.0\", topics: [{ path: TOPIC_DN_STATE, type: \"state\", value: dnDB }] };\n\nreturn [\n    [{ topic: TOPIC_PICK_QUEUE, payload: payloadQueue }, { topic: TOPIC_DN_STATE, payload: payloadDN }]\n];",

    {
        "id": "mqtt_in_add_to_wave",
        "type": "mqtt in",
        "z": "99f9fe79da9e4937",
        "g": "c7ca76b09ddf4c7e",
        "name": "Action: Add_To_Wave",
        "topic": "Henkelv2/Shanghai/Logistics/Outbound/Action/Add_To_Wave",
        "qos": "0",
        "datatype": "json",
        "broker": "a749d056cff1a785",

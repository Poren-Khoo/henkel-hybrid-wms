        "type": "function",
        "z": "99f9fe79da9e4937",
        "g": "c7ca76b09ddf4c7e",
        "name": "Confirm Load",
        "func": "const TOPIC_SHIPMENT = \"Henkelv2/Shanghai/Logistics/Outbound/State/Shipment_List\";\nconst TOPIC_DOCKS = \"Henkelv2/Shanghai/Logistics/Outbound/State/Loading_Docks\";\n\nlet action = msg.payload;\n// Expected: { dock_id, shipment_id, operator, timestamp }\n\nlet shipmentList = global.get('shipment_list') || { items: [] };\nif (!shipmentList.items) shipmentList.items = [];\n\nlet docks = global.get('loading_docks') || { docks: [] };\nif (!docks.docks || !Array.isArray(docks.docks)) {\n    docks.docks = [\n        { dock_id: 'DOCK-01', status: 'AVAILABLE', shipment_id: null },\n        { dock_id: 'DOCK-02', status: 'AVAILABLE', shipment_id: null }\n    ];\n}\n\nlet ship = shipmentList.items.find(s => s.shipment_id === action.shipment_id || s.dn_id === action.shipment_id);\nif (ship) {\n    ship.status = 'LOADED';\n    ship.loaded_at = Date.now();\n    ship.dock_id = action.dock_id;\n}\n\nlet dock = docks.docks.find(d => d.dock_id === action.dock_id);\nif (dock) {\n    dock.status = 'AVAILABLE';\n    dock.shipment_id = null;\n}\n\nglobal.set('shipment_list', shipmentList);\nglobal.set('loading_docks', docks);\n\nlet msgShip = {\n    topic: TOPIC_SHIPMENT,\n    payload: { version: \"1.0\", topics: [{ path: TOPIC_SHIPMENT, type: \"state\", value: shipmentList }] }\n};\nlet msgDocks = {\n    topic: TOPIC_DOCKS,\n    payload: { version: \"1.0\", topics: [{ path: TOPIC_DOCKS, type: \"state\", value: docks }] }\n};\n\nreturn [msgShip, msgDocks];",

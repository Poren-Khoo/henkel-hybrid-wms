    {
        "id": "mqtt_in_confirm_delivery",
        "type": "mqtt in",
        "z": "99f9fe79da9e4937",
        "g": "c7ca76b09ddf4c7e",
        "name": "Action: Confirm_Delivery",
        "topic": "Henkelv2/Shanghai/Logistics/Outbound/Action/Confirm_Delivery",
        "qos": "0",
        "datatype": "json",
        "broker": "a749d056cff1a785",
        "inputs": 0,
        "x": 2310,
        "y": 740,
        "wires": [
            [
                "func_confirm_delivery"
            ]
        ]
    },
    {
        "id": "func_confirm_delivery",
        "type": "function",
        "z": "99f9fe79da9e4937",
        "g": "c7ca76b09ddf4c7e",
        "name": "Confirm Delivery (Manufacturing)",
        "func": "// TOPICS\nconst TOPIC_DN_STATE = \"Henkelv2/Shanghai/Logistics/Outbound/State/DN_Workflow\";\nconst TOPIC_INVENTORY = \"Henkelv2/Shanghai/Logistics/Internal/Ops/State/Inventory_Level\";\n\nlet action = msg.payload;\n// Expected: { dn_no, production_line }\n\n// 1. Get DBs\nlet dnDB = global.get('outbound_dn_db') || { items: [] };\nlet inventory = global.get('internal_stock_list') || [];\nlet taskDB = global.get('outbound_task_db') || { items: [] };\n\n// 2. Find order\nlet order = dnDB.items.find(o => o.dn_no === action.dn_no || o.id === action.dn_no);\nif (!order) {\n    node.warn(\"Confirm Delivery Error: Order not found \" + action.dn_no);\n    return null;\n}\n\n// 3. Validate status - must be PICKED\nconst canDeliver = ['PICKED', 'PICKING'].includes((order.status || '').toUpperCase());\nif (!canDeliver) {\n    node.warn(\"Confirm Delivery Error: Order not ready for delivery. Status: \" + order.status);\n    return null;\n}\n\n// 4. Update order status to DELIVERED (terminal for manufacturing)\norder.status = 'DELIVERED';\norder.delivered_at = Date.now();\norder.delivered_by = action.operator || 'System';\norder.production_line = action.production_line || order.destination;\n\n// 5. Deduct inventory for all allocated batches\n(order.lines || []).forEach(line => {\n    // Find and remove allocated inventory\n    let allocated = inventory.filter(item =>\n        item.allocated_to === (order.dn_no || order.id) &&\n        item.sku === line.code\n    );\n    \n    allocated.forEach(item => {\n        // Mark as consumed (could also remove from inventory)\n        item.status = 'CONSUMED';\n        item.consumed_at = Date.now();\n        item.consumed_by = order.dn_no || order.id;\n        item.location = action.production_line || 'PRODUCTION';\n    });\n});\n\n// 6. Update related pick tasks to COMPLETED\ntaskDB.items.forEach(task => {\n    if (task.dn_no === (order.dn_no || order.id)) {\n        task.status = 'COMPLETED';\n        task.completed_at = Date.now();\n    }\n});\n\n// 7. Save\nglobal.set('outbound_dn_db', dnDB);\nglobal.set('internal_stock_list', inventory);\nglobal.set('outbound_task_db', taskDB);\n\n// 8. Prepare outputs\nlet msgDN = {\n    topic: TOPIC_DN_STATE,\n    payload: { version: \"1.0\", topics: [{ path: TOPIC_DN_STATE, type: \"state\", value: dnDB }] }\n};\n\nlet msgInv = {\n    topic: TOPIC_INVENTORY,\n    payload: { version: \"1.0\", topics: [{ path: TOPIC_INVENTORY, type: \"state\", value: { last_updated: Date.now(), stock_items: inventory } }] }\n};\n\nreturn [msgDN, msgInv];",

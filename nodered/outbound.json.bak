        "func": "const TOPIC_SHIPMENT = \"Henkelv2/Shanghai/Logistics/Outbound/State/Shipment_List\";\n\nlet action = msg.payload;\n// Expected: { dn_id, operator, timestamp }\n\nlet shipmentList = global.get('shipment_list') || { items: [] };\n\nlet ship = shipmentList.items.find(s => s.dn_id === action.dn_id || s.shipment_id === action.dn_id);\nif (!ship) {\n    node.warn(\"Confirm Outbound Pick: Shipment not found \" + action.dn_id);\n    return null;\n}\n\nship.status = 'PICKED';\nship.picked_at = Date.now();\nship.picked_by = action.operator || 'System';\n\nglobal.set('shipment_list', shipmentList);\n\nmsg.topic = TOPIC_SHIPMENT;\nmsg.payload = {\n    version: \"1.0\",\n    topics: [{ path: TOPIC_SHIPMENT, type: \"state\", value: shipmentList }] \n};\nreturn msg;",

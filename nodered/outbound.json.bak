    {
        "id": "mqtt_in_allocate_dn",
        "type": "mqtt in",
        "z": "99f9fe79da9e4937",
        "g": "c7ca76b09ddf4c7e",
        "name": "Action: Allocate_DN (Direct)",
        "topic": "Henkelv2/Shanghai/Logistics/Outbound/Action/Allocate_DN",
        "qos": "0",
        "datatype": "json",
        "broker": "a749d056cff1a785",
        "inputs": 0,
        "x": 2320,
        "y": 660,
        "wires": [
            [
                "func_allocate_dn"
            ]
        ]
    },
    {
        "id": "func_allocate_dn",
        "type": "function",
        "z": "99f9fe79da9e4937",
        "g": "c7ca76b09ddf4c7e",
        "name": "Direct Allocation (Manufacturing)",
        "func": "// TOPICS\nconst TOPIC_DN_STATE = \"Henkelv2/Shanghai/Logistics/Outbound/State/DN_Workflow\";\nconst TOPIC_INVENTORY = \"Henkelv2/Shanghai/Logistics/Internal/Ops/State/Inventory_Level\";\nconst TOPIC_TASKS = \"Henkelv2/Shanghai/Logistics/Outbound/State/Picking_Tasks\";\n\nlet action = msg.payload;\n// Expected: { dn_no }\n\n// 1. Get DBs\nlet dnDB = global.get('outbound_dn_db') || { items: [] };\nlet inventory = global.get('internal_stock_list') || [];\nlet taskDB = global.get('outbound_task_db') || { items: [] };\n\n// 2. Find order\nlet order = dnDB.items.find(o => o.dn_no === action.dn_no || o.id === action.dn_no);\nif (!order) {\n    node.warn(\"Allocate DN Error: Order not found \" + action.dn_no);\n    return null;\n}\n\n// 3. Validate status\nconst canAllocate = ['RELEASED', 'APPROVED', 'NEW'].includes((order.status || '').toUpperCase());\nif (!canAllocate) {\n    node.warn(\"Allocate DN Error: Cannot allocate order in status \" + order.status);\n    return null;\n}\n\norder.status = 'ALLOCATING';\n\n// 4. FEFO Allocation for each line\n(order.lines || []).forEach(line => {\n    let candidates = inventory.filter(item =>\n        item.sku === line.code &&\n        item.status === 'AVAILABLE'\n    );\n    \n    candidates.sort((a, b) => {\n        let dateA = a.expiry_date || 9999999999999;\n        let dateB = b.expiry_date || 9999999999999;\n        return dateA - dateB;\n    });\n    \n    let needed = line.qty || 0;\n    let allocated = 0;\n    \n    for (let batch of candidates) {\n        if (needed <= 0) break;\n        if (batch.qty <= 0) continue;\n        \n        let takeQty = Math.min(batch.qty, needed);\n        \n        batch.status = 'ALLOCATED';\n        batch.allocated_to = order.dn_no || order.id;\n        \n        // Create pick task - for manufacturing, destination is production line\n        let newTask = {\n            task_id: 'PICK-' + Date.now() + '-' + Math.floor(Math.random() * 1000),\n            dn_no: order.dn_no || order.id,\n            batch_id: batch.batch_id,\n            material_code: batch.sku,\n            material_name: batch.desc,\n            qty: takeQty,\n            from_loc: batch.location || 'ZONE-A',\n            to_loc: order.production_line || order.destination || 'LINE-SIDE-A',\n            status: 'PENDING',\n            context: 'MANUFACTURING',\n            priority: order.priority || 'NORMAL',\n            created_at: Date.now()\n        };\n        taskDB.items.unshift(newTask);\n        \n        needed -= takeQty;\n        allocated += takeQty;\n    }\n    \n    line.qty_allocated = allocated;\n});\n\n// 5. Update order status\nlet allAllocated = (order.lines || []).every(l => (l.qty_allocated || 0) >= (l.qty || 0));\n\nif (allAllocated) {\n    order.status = 'ALLOCATED';\n    order.allocated_at = Date.now();\n} else {\n    order.status = 'BACKORDER';\n}\n\n// 6. Save\nglobal.set('outbound_dn_db', dnDB);\nglobal.set('internal_stock_list', inventory);\nglobal.set('outbound_task_db', taskDB);\n\n// 7. Prepare outputs\nlet msgDN = {\n    topic: TOPIC_DN_STATE,\n    payload: { version: \"1.0\", topics: [{ path: TOPIC_DN_STATE, type: \"state\", value: dnDB }] }\n};\n\nlet msgInv = {\n    topic: TOPIC_INVENTORY,\n    payload: { version: \"1.0\", topics: [{ path: TOPIC_INVENTORY, type: \"state\", value: { last_updated: Date.now(), stock_items: inventory } }] }\n};\n\nlet msgTasks = {\n    topic: TOPIC_TASKS,\n    payload: { version: \"1.0\", topics: [{ path: TOPIC_TASKS, type: \"state\", value: taskDB }] }\n};\n\nreturn [msgDN, msgInv, msgTasks];",

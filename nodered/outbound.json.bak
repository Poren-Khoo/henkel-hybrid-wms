    {
        "id": "func_generate_wave_list",
        "type": "function",
        "z": "99f9fe79da9e4937",
        "g": "group_mock_data_generators",
        "name": "Generate Waves",
        "func": "const statuses = ['PLANNED', 'RELEASED', 'IN_PROGRESS', 'COMPLETED'];\nconst carriers = ['SF-EXPRESS', 'DHL', 'SINOTRANS', 'JD-LOGISTICS'];\nconst routes = ['Shanghai North', 'Shanghai South', 'Suzhou Route', 'Hangzhou Line'];\n\nlet waveDB = global.get('wave_db') || { items: [] };\n\n// Generate 2-4 new waves\nlet count = Math.floor(Math.random() * 3) + 2;\nfor (let i = 0; i < count; i++) {\n    let status = statuses[Math.floor(Math.random() * statuses.length)];\n    let totalPicks = Math.floor(Math.random() * 20) + 5;\n    let completedPicks = status === 'COMPLETED' ? totalPicks :\n        status === 'IN_PROGRESS' ? Math.floor(totalPicks * Math.random()) : 0;\n\n    // 格式: WAVE-20260205-001 — 在对象外面先算好\n    let datePart = new Date().toISOString().slice(0, 10).replace(/-/g, '');\n    let key = 'wave_seq_' + datePart;\n    let seq = (global.get(key) || 0) + 1;\n    global.set(key, seq);\n\n    let wave = {\n        wave_id: 'WAVE-' + datePart + '-' + String(seq).padStart(3, '0'),\n        status: status,\n        ship_date: new Date(Date.now() + 86400000 * Math.floor(Math.random() * 3)).toISOString().split('T')[0],\n        carrier: carriers[Math.floor(Math.random() * carriers.length)],\n        route: routes[Math.floor(Math.random() * routes.length)],\n        pick_method: Math.random() > 0.5 ? 'BATCH' : 'DISCRETE',\n        delivery_ids: [],\n        delivery_count: Math.floor(Math.random() * 5) + 1,\n        line_count: Math.floor(Math.random() * 15) + 3,\n        picks_completed: completedPicks,\n        picks_total: totalPicks,\n        created_at: Date.now()\n    };\n    waveDB.items.unshift(wave);\n}\n\nif (waveDB.items.length > 15) waveDB.items = waveDB.items.slice(0, 15);\nglobal.set('wave_db', waveDB);\n\nmsg.payload = {\n    version: '1.0',\n    topics: [{ path: msg.topic, type: 'state', value: waveDB }]\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 1730,
        "y": 1000,
        "wires": [
            [
                "mqtt_out_mock_state",
                "debug_mock_output"
            ]
        ]
    },

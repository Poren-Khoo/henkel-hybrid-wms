    {
        "id": "5a96d0513b0fdeeb",
        "type": "mqtt in",
        "z": "99f9fe79da9e4937",
        "g": "2a38c4b3bb8c00eb",
        "name": "Listen: Review_DN",
        "topic": "Henkelv2/Shanghai/Logistics/Costing/Action/Review_DN",
        "qos": "0",
        "datatype": "json",
        "broker": "a749d056cff1a785",
        "nl": false,
        "rap": false,

        "name": "Report Short Pick",
        "func": "const TOPIC_PICK_QUEUE = \"Henkelv2/Shanghai/Logistics/Outbound/State/Picking_Queue\";\n\nlet action = msg.payload;\n// Expected: { task_id, sku?, location?, reason, operator, timestamp } or { task_id, expected_qty, actual_qty, reason, ... }\n\nlet taskDB = global.get('outbound_task_db') || { items: [] };\n\nlet task = taskDB.items.find(t => t.task_id === action.task_id);\nif (!task) {\n    node.warn(\"Report Short Pick: Task not found \" + action.task_id);\n    return null;\n}\n\ntask.status = 'SHORT_PICK';\ntask.short_reason = action.reason || 'UNKNOWN';\ntask.actual_qty = action.actual_qty ?? action.qty_picked ?? 0;\ntask.expected_qty = action.expected_qty ?? task.qty;\ntask.operator = action.operator || 'System';\ntask.updated_at = Date.now();\n\nglobal.set('outbound_task_db', taskDB);\n\nmsg.topic = TOPIC_PICK_QUEUE;\nmsg.payload = {\n    version: \"1.0\",\n    topics: [{ path: TOPIC_PICK_QUEUE, type: \"state\", value: { tasks: taskDB.items } }]\n};\nreturn msg;",

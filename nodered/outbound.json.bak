    {
        "id": "6ef1104b6dd3bd38",
        "type": "function",
        "z": "99f9fe79da9e4937",
        "g": "c7ca76b09ddf4c7e",
        "name": "Delete Wave",
        "func": "const TOPIC_WAVE_STATE = \"Henkelv2/Shanghai/Logistics/Outbound/State/Wave_List\";\nconst TOPIC_DN_STATE = \"Henkelv2/Shanghai/Logistics/Outbound/State/DN_Workflow\";\n\nlet action = msg.payload;\n// Expected: { wave_id, action: 'CANCEL_WAVE', reason?, timestamp }\n\nlet waveDB = global.get('wave_db') || { items: [] };\nlet dnDB = global.get('outbound_dn_db') || { items: [] };\n\nlet wave = waveDB.items.find(w => w.wave_id === action.wave_id);\nif (!wave) {\n    node.warn(\"Delete Wave: Wave not found \" + action.wave_id);\n    return null;\n}\n\nif (wave.status !== 'PLANNED' && wave.status !== 'RELEASED') {\n    node.warn(\"Delete Wave: Cannot delete wave in status \" + wave.status);\n    return null;\n}\n\n// Unassign orders from this wave\n(wave.delivery_ids || []).forEach(dnId => {\n    let order = dnDB.items.find(o => o.dn_no === dnId || o.id === dnId);\n    if (order) {\n        order.wave_id = null;\n        order.status = 'RELEASED';\n    }\n});\n\n// Remove wave\nwaveDB.items = waveDB.items.filter(w => w.wave_id !== action.wave_id);\n\nglobal.set('wave_db', waveDB);\nglobal.set('outbound_dn_db', dnDB);\n\nlet msgWave = {\n    topic: TOPIC_WAVE_STATE,\n    payload: { version: \"1.0\", topics: [{ path: TOPIC_WAVE_STATE, type: \"state\", value: waveDB }] }\n};\nlet msgDN = {\n    topic: TOPIC_DN_STATE,\n    payload: { version: \"1.0\", topics: [{ path: TOPIC_DN_STATE, type: \"state\", value: dnDB }] }\n};\n\nreturn [msgWave, msgDN];",

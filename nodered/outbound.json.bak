        "name": "Create Shipment",
        "func": "const TOPIC_SHIPMENT = \"Henkelv2/Shanghai/Logistics/Outbound/State/Shipment_List\";\n\nlet action = msg.payload;\n// Expected: { customer, destination, items: [{ sku, qty }], created_by }\n\nlet shipmentList = global.get('shipment_list') || { items: [] };\nif (!shipmentList.items) shipmentList.items = [];\n\nlet shipment_id = 'SHP-' + Date.now();\nlet newShipment = {\n    shipment_id: shipment_id,\n    dn_id: shipment_id,\n    customer: action.customer || 'Unknown',\n    destination: action.destination || '',\n    items: action.items || [],\n    status: 'READY_TO_PICK',\n    created_at: Date.now(),\n    created_by: action.created_by || 'System'\n};\n\nshipmentList.items.unshift(newShipment);\nif (shipmentList.items.length > 50) shipmentList.items = shipmentList.items.slice(0, 50);\n\nglobal.set('shipment_list', shipmentList);\n\nmsg.topic = TOPIC_SHIPMENT;\nmsg.payload = {\n    version: \"1.0\",\n    topics: [{ path: TOPIC_SHIPMENT, type: \"state\", value: shipmentList }]\n};\nreturn msg;",

        ]
    },
    {
        "id": "func_release_hold",
        "type": "function",
        "z": "99f9fe79da9e4937",
        "g": "c7ca76b09ddf4c7e",
        "name": "Release Hold",
        "func": "// TOPICS\nconst TOPIC_DN_STATE = \"Henkelv2/Shanghai/Logistics/Outbound/State/DN_Workflow\";\n\nlet action = msg.payload;\n// Expected: { dn_no, action: 'RELEASE_HOLD' }\n\n// 1. Get order DB\nlet dnDB = global.get('outbound_dn_db') || { items: [] };\n\n// 2. Find the order\nlet orderIndex = dnDB.items.findIndex(o => o.dn_no === action.dn_no || o.id === action.dn_no);\nif (orderIndex === -1) {\n    node.warn(\"Release Hold Error: Order not found \" + action.dn_no);\n    return null;\n}\n\nlet order = dnDB.items[orderIndex];\n\n// 3. Validate - must be on hold\nif ((order.status || '').toUpperCase() !== 'ON_HOLD') {\n    node.warn(\"Release Hold Error: Order not on hold. Current status: \" + order.status);\n    return null;\n}\n\n// 4. Restore previous status or default to RELEASED\norder.status = order.previous_status || 'RELEASED';\norder.on_hold = false;\norder.hold_reason = null;\norder.released_hold_at = Date.now();\norder.released_hold_by = action.operator || 'System';\n\n// Clear previous status tracking\ndelete order.previous_status;\ndelete order.hold_timestamp;\ndelete order.hold_by;\n\n// 5. Save\nglobal.set('outbound_dn_db', dnDB);\n\n// 6. Publish\nmsg.topic = TOPIC_DN_STATE;\nmsg.payload = {\n    version: \"1.0\",\n    topics: [{ path: TOPIC_DN_STATE, type: \"state\", value: dnDB }]\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 2560,
        "y": 180,

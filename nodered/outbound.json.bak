        "name": "Submit VAS",
        "func": "const TOPIC_COST_DB = \"Henkelv2/Shanghai/Logistics/Costing/State/DN_Workflow_DB\";\n\nlet action = msg.payload;\n// Expected: { dn_no, destination?, is_urgent, need_repack, custom_label, special_notes }\n\nlet allDNs = global.get('dn_db') || {};\nlet dnRecord = allDNs[action.dn_no];\nif (!dnRecord) {\n    node.warn(\"Submit VAS: DN not found \" + action.dn_no);\n    return null;\n}\n\ndnRecord.vas_requested = true;\ndnRecord.vas_urgent = action.is_urgent || false;\ndnRecord.vas_repack = action.need_repack || false;\ndnRecord.vas_custom_label = action.custom_label || false;\ndnRecord.vas_notes = action.special_notes || '';\ndnRecord.vas_submitted_at = Date.now();\n\nglobal.set('dn_db', allDNs);\n\nmsg.topic = TOPIC_COST_DB;\nmsg.payload = {\n    version: \"1.0\",\n    topics: [{ path: TOPIC_COST_DB, type: \"state\", value: Object.values(allDNs) }]\n};\nreturn msg;",
